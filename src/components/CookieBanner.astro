<div id="cookie-banner" class="fixed bottom-0 left-0 right-0 z-50 bg-primary border-t border-white/10 shadow-2xl translate-y-full transition-transform duration-500 ease-out" role="dialog" aria-live="polite" aria-label="Cookie-Einwilligung">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-6">
    <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-4">
      <div class="flex-1 max-w-3xl">
        <h3 class="text-white font-semibold text-sm mb-2">Datenschutzeinstellungen</h3>
        <p class="text-white/70 text-sm leading-relaxed">
          Wir verwenden Cookies ausschließlich für technisch notwendige Funktionen (z. B. Speicherung Ihrer Cookie-Einstellung). 
          Es werden keine Tracking- oder Analyse-Cookies eingesetzt. Weitere Informationen finden Sie in unserer 
          <a href="/datenschutz" class="text-accent underline hover:no-underline transition-all">Datenschutzerklärung</a>.
        </p>
      </div>
      <div class="flex items-center gap-3 flex-shrink-0">
        <button
          id="cookie-decline"
          type="button"
          class="px-4 py-2 text-sm text-white/80 border border-white/20 rounded hover:bg-white/10 transition-all duration-300"
        >
          Ablehnen
        </button>
        <button
          id="cookie-accept"
          type="button"
          class="px-4 py-2 text-sm bg-accent text-white rounded hover:bg-accent/90 transition-all duration-300 shadow-lg"
        >
          Akzeptieren
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  (function() {
    const STORAGE_KEY = 'cookie-consent-mf';
    const banner = document.getElementById('cookie-banner');
    const acceptBtn = document.getElementById('cookie-accept');
    const declineBtn = document.getElementById('cookie-decline');
    
    if (!banner) return;
    
    // Check existing consent
    const existingConsent = localStorage.getItem(STORAGE_KEY);
    
    if (!existingConsent) {
      // Show banner after short delay
      setTimeout(() => {
        banner.classList.remove('translate-y-full');
      }, 1000);
    }
    
    function hideBanner() {
      banner.classList.add('translate-y-full');
      setTimeout(() => {
        banner.style.display = 'none';
      }, 500);
    }
    
    function setConsent(accepted) {
      localStorage.setItem(STORAGE_KEY, JSON.stringify({
        accepted: accepted,
        timestamp: new Date().toISOString(),
        necessary: true,
        analytics: false,
        marketing: false
      }));
      hideBanner();
      
      // Dispatch custom event for other components
      window.dispatchEvent(new CustomEvent('cookieConsentUpdated', { 
        detail: { accepted, necessary: true, analytics: false, marketing: false }
      }));
    }
    
    if (acceptBtn) {
      acceptBtn.addEventListener('click', () => setConsent(true));
    }
    
    if (declineBtn) {
      declineBtn.addEventListener('click', () => setConsent(false));
    }
  })();
</script>
