---
const currentYear = new Date().getFullYear();
---

<footer class="bg-primary text-white/80">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">
      
      <!-- Column 1: Logo & About -->
      <div class="space-y-4">
        <a href="/" class="inline-block group" aria-label="Montagebau Fabian - Zur Startseite">
          <div class="bg-white rounded-xl p-3 shadow-lg">
            <img 
              src="/logo.jpg" 
              alt="Montagebau Fabian Logo" 
              class="h-10 w-auto max-w-[160px] object-contain"
              loading="lazy"
            />
          </div>
        </a>
        <p class="text-sm leading-relaxed text-white/70">
          Ihr erfahrener Partner für Montagebau & Bauelemente. Verkauf und Montage aus einer Hand – zuverlässig, qualitativ und immer für Sie da.
        </p>
      </div>

      <!-- Column 2: Quick Links -->
      <div>
        <h3 class="text-white font-semibold text-sm uppercase tracking-wider mb-4">Navigation</h3>
        <ul class="space-y-3">
          <li>
            <a href="/" class="text-sm text-white/70 hover:text-accent transition-colors duration-300">Startseite</a>
          </li>
          <li>
            <a href="/leistungen" class="text-sm text-white/70 hover:text-accent transition-colors duration-300">Leistungen</a>
          </li>
          <li>
            <a href="/ueber-uns" class="text-sm text-white/70 hover:text-accent transition-colors duration-300">Über Uns</a>
          </li>
          <li>
            <a href="/kontakt" class="text-sm text-white/70 hover:text-accent transition-colors duration-300">Kontakt</a>
          </li>
        </ul>
      </div>

      <!-- Column 3: Contact -->
      <div>
        <h3 class="text-white font-semibold text-sm uppercase tracking-wider mb-4">Kontakt</h3>
        <address class="not-italic space-y-3 text-sm">
          <p class="flex items-start gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-accent flex-shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
            <span>Am Dohrbaum 5<br/>58239 Schwerte</span>
          </p>
          <p class="flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-accent flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
            <a href="tel:+4915156081392" class="hover:text-accent transition-colors duration-300">0151 56081392</a>
          </p>
          <p class="flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-accent flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect width="20" height="16" x="2" y="4" rx="2"/>
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
            </svg>
            <a href="mailto:montagebau-fabian@gmx.de" class="hover:text-accent transition-colors duration-300">montagebau-fabian@gmx.de</a>
          </p>
        </address>
      </div>

      <!-- Column 4: Legal -->
      <div>
        <h3 class="text-white font-semibold text-sm uppercase tracking-wider mb-4">Rechtliches</h3>
        <ul class="space-y-3">
          <li>
            <a href="/impressum" class="text-sm text-white/70 hover:text-accent transition-colors duration-300">Impressum</a>
          </li>
          <li>
            <a href="/datenschutz" class="text-sm text-white/70 hover:text-accent transition-colors duration-300">Datenschutz</a>
          </li>
        </ul>
        <div class="mt-6 pt-6 border-t border-white/10">
          <p class="text-xs text-white/50">
            Steuernr.: 316/5069/3083<br/>
            USt-ID: DE260511610
          </p>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="border-t border-white/10">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-6">
      <p class="text-center text-xs text-white/50">
        © {currentYear} Montagebau Fabian – Manuela Fabian. Alle Rechte vorbehalten.
      </p>
    </div>
  </div>
</footer>
