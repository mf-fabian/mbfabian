---
import SEOHead from '../components/SEOHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CookieBanner from '../components/CookieBanner.astro';
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  noindex?: boolean;
}

const { title, description, canonical, ogImage, noindex } = Astro.props;
---

<!DOCTYPE html>
<html lang="de" dir="ltr">
  <head>
    <SEOHead 
      title={title} 
      description={description} 
      canonical={canonical} 
      ogImage={ogImage}
      noindex={noindex}
    />
  </head>
  <body class="min-h-screen flex flex-col bg-bg text-text antialiased">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[60] focus:bg-accent focus:text-white focus:px-4 focus:py-2 focus:rounded">
      Zum Hauptinhalt springen
    </a>
    
    <Header />
    
    <main id="main-content" class="flex-1">
      <slot />
    </main>
    
    <Footer />
    <CookieBanner />
  </body>
</html>
