---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import heroImage from '../assets/hero.jpeg';
import tuerImage from '../assets/tuer.jpg';
import fensterImage from '../assets/fenster.jpg';
import zaunImage from '../assets/zaun.jpg';
import qualitaetTeamImage from '../assets/qualitaet-team.jpg';
---

<Layout 
  title="Premium Montagebau & Bauelemente – Seit 2008"
  description="Montagebau Fabian: Ihr Experte für Türen, Tore, Fenster, Überdachungen und Zäune. Verkauf & Montage aus einer Hand. ✓ Seit 2008 ✓ Hörmann Partner"
>
  <!-- HERO SECTION -->
  <section class="relative bg-primary overflow-hidden min-h-[600px] lg:min-h-[700px] flex items-center" aria-labelledby="hero-heading">
    <!-- Background Image -->
    <div class="absolute inset-0">
      <Image 
        src={heroImage} 
        alt="Moderne Haustür Montagebau Fabian" 
        class="w-full h-full object-cover"
        width={1400}
        loading="eager"
        fetchpriority="high"
        densities={[1, 2]} decoding="async"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-primary/90 via-primary/80 to-primary/60"></div>
    </div>
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-24 lg:py-32 w-full">
      <div class="max-w-2xl">
        <h1 id="hero-heading" class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white leading-tight mb-6">
          Premium Montagebau &amp; Bauelemente – <span class="text-accent">Seit 2008.</span>
        </h1>
        <p class="text-lg sm:text-xl text-white/80 mb-8 leading-relaxed">
          Verkauf, Montage und Service für Türen, Tore, Fenster und Zäune. 
          Als erfahrener Partner namhafter Hersteller stehen wir Ihnen mit Rat und Tat zur Seite – 
          bei bestehenden Projekten.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a 
            href="/kontakt" 
            class="inline-flex items-center justify-center gap-2 bg-accent text-white px-8 py-4 rounded font-semibold text-base transition-all duration-300 hover:bg-accent/90 hover:scale-105 shadow-lg hover:shadow-xl"
          >
            Kostenlose Beratung anfordern
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
            </svg>
          </a>
          <a 
            href="/leistungen" 
            class="inline-flex items-center justify-center gap-2 border-2 border-white/30 text-white px-8 py-4 rounded font-semibold text-base transition-all duration-300 hover:border-white hover:bg-white/10"
          >
            Unsere Leistungen
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- TRUST BANNER -->
  <section class="bg-primary border-t border-white/10" aria-label="Partner und Hersteller">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-8">
      <div class="flex flex-col md:flex-row items-center justify-center gap-6 md:gap-12">
        <span class="text-white/60 text-sm font-medium uppercase tracking-wider">Erfahrener Partner von:</span>
        <div class="flex flex-wrap items-center justify-center gap-8 md:gap-12">
          <span class="text-white font-semibold text-lg opacity-80 hover:opacity-100 transition-opacity">Hörmann</span>
          <span class="text-white font-semibold text-lg opacity-80 hover:opacity-100 transition-opacity">DMW Schwarze</span>
          <span class="text-white font-semibold text-lg opacity-80 hover:opacity-100 transition-opacity">EGE</span>
          <span class="text-white font-semibold text-lg opacity-80 hover:opacity-100 transition-opacity">Jotec</span>
        </div>
      </div>
    </div>
  </section>

  <!-- LEISTUNGEN GRID -->
  <section class="py-20 lg:py-28 bg-bg" aria-labelledby="services-heading">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 id="services-heading" class="text-3xl sm:text-4xl font-bold text-primary mb-4">
          Unsere Leistungen
        </h2>
        <p class="text-lg text-text-muted max-w-2xl mx-auto">
          Vom hochwertigen Einzelprodukt bis zur kompletten Projektrealisierung – wir bieten Ihnen alles aus einer Hand.
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Card 1: Türen & Tore -->
        <article class="group bg-white rounded-xl border border-border overflow-hidden transition-all duration-300 hover:shadow-xl hover:-translate-y-1">
          <div class="aspect-[4/3] overflow-hidden">
            <Image 
              src={tuerImage} 
              alt="Haustüren von Montagebau Fabian" 
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
              width={800}
              loading="lazy"
              densities={[1, 2]} decoding="async"
            />
          </div>
          <div class="p-8">
            <h3 class="text-xl font-bold text-primary mb-3">Türen &amp; Tore</h3>
            <p class="text-text-muted mb-6 leading-relaxed">
              Brandschutztüren, Garagensektionaltore, Haustüren, Rolltore, Zimmertüren, Industrie-Sektional-Rolltore, Mehrzwecktüren und Brandschutzschiebetore.
            </p>
            <a href="/leistungen#tueren" class="inline-flex items-center gap-2 text-accent font-semibold hover:gap-3 transition-all duration-300">
              Mehr erfahren
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
              </svg>
            </a>
          </div>
        </article>

        <!-- Card 2: Fenster & Überdachungen -->
        <article class="group bg-white rounded-xl border border-border overflow-hidden transition-all duration-300 hover:shadow-xl hover:-translate-y-1">
          <div class="aspect-[4/3] overflow-hidden">
            <Image 
              src={fensterImage} 
              alt="Fenster und Glasfronten von Montagebau Fabian" 
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
              width={800}
              loading="lazy"
              densities={[1, 2]} decoding="async"
            />
          </div>
          <div class="p-8">
            <h3 class="text-xl font-bold text-primary mb-3">Fenster &amp; Überdachungen</h3>
            <p class="text-text-muted mb-6 leading-relaxed">
              Fenster, Terassenüberdachungen, Rolladen, Lamellendächer aus Aluminium und Holz, Insektenschutz, Vordächer, Sonnenschutz, Beschattung und Carports.
            </p>
            <a href="/leistungen#fenster" class="inline-flex items-center gap-2 text-accent font-semibold hover:gap-3 transition-all duration-300">
              Mehr erfahren
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
              </svg>
            </a>
          </div>
        </article>

        <!-- Card 3: Zäune -->
        <article class="group bg-white rounded-xl border border-border overflow-hidden transition-all duration-300 hover:shadow-xl hover:-translate-y-1">
          <div class="aspect-[4/3] overflow-hidden">
            <Image 
              src={zaunImage} 
              alt="Zaunanlagen von Montagebau Fabian" 
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
              width={800}
              loading="lazy"
              densities={[1, 2]} decoding="async"
            />
          </div>
          <div class="p-8">
            <h3 class="text-xl font-bold text-primary mb-3">Zäune</h3>
            <p class="text-text-muted mb-6 leading-relaxed">
              Aluminiumplankenzäune, Sandwichplatten und Doppelstabmatten für Privat und Gewerbe. Maßgefertigte Lösungen für jeden Anspruch.
            </p>
            <a href="/leistungen#zaeune" class="inline-flex items-center gap-2 text-accent font-semibold hover:gap-3 transition-all duration-300">
              Mehr erfahren
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
              </svg>
            </a>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- WHY US / ÜBER UNS TEASER -->
  <section class="py-20 lg:py-28 bg-surface" aria-labelledby="why-us-heading">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <!-- Image Side -->
        <div class="relative">
          <div class="aspect-[4/3] rounded-2xl overflow-hidden border border-border shadow-lg">
            <Image 
              src={qualitaetTeamImage} 
              alt="Team von Montagebau Fabian bei der Arbeit" 
              class="w-full h-full object-cover"
              width={800}
              loading="lazy"
              densities={[1, 2]} decoding="async"
            />
          </div>
          <!-- Experience Badge -->
          <div class="absolute -bottom-6 -right-6 bg-accent text-white rounded-xl p-6 shadow-xl hidden lg:block">
            <span class="text-4xl font-bold">15+</span>
            <p class="text-sm text-white/90">Jahre Erfahrung</p>
          </div>
        </div>

        <!-- Text Side -->
        <div>
          <h2 id="why-us-heading" class="text-3xl sm:text-4xl font-bold text-primary mb-6">
            Qualität, auf die Sie bauen können.
          </h2>
          <div class="space-y-4 text-text-light leading-relaxed">
            <p>
              Seit der Gründung im Jahr 2008 steht Montagebau Fabian unter der Leitung von Manuela Fabian für 
              erstklassige Montageleistungen im Bereich Bauelemente. Wir sind nicht nur vor Ort für unsere Kunden 
              da, sondern arbeiten seit vielen Jahren erfolgreich als Subunternehmer für führende Hersteller wie 
              <strong>Hörmann, Jotec, EGE</strong> und <strong>DMW Schwarze</strong>.
            </p>
            <p>
              Diese langjährigen Partnerschaften sprechen für sich: Große Unternehmen vertrauen auf unsere 
              Präzision, Termintreue und fachliche Kompetenz. Wir montieren nach höchsten Standards – 
              egal ob bei komplexen Industrieprojekten oder anspruchsvollen Gewerbeaufträgen.
            </p>
            <p>
              Bei dringenden Problemen sind wir schnell vor Ort – kompetent, lösungsorientiert und zuverlässig.
            </p>
          </div>
          <div class="mt-8 flex flex-col sm:flex-row gap-4">
            <a href="/ueber-uns" class="inline-flex items-center gap-2 text-accent font-semibold hover:gap-3 transition-all duration-300">
              Mehr über uns erfahren
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA BANNER -->
  <section class="py-16 lg:py-20 bg-accent" aria-labelledby="contact-heading">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center">
      <h2 id="contact-heading" class="text-3xl sm:text-4xl font-bold text-white mb-6">
        Haben Sie Fragen zu unseren Leistungen?
      </h2>
      <p class="text-lg text-white/90 mb-8 max-w-2xl mx-auto">
        Wir beraten Sie gerne persönlich – ob telefonisch oder vor Ort in Schwerte und Umgebung.
      </p>
      <a 
        href="tel:+4915156081392" 
        class="inline-flex items-center justify-center gap-3 bg-white text-accent px-10 py-5 rounded-xl font-bold text-xl transition-all duration-300 hover:bg-white/95 hover:scale-105 shadow-xl"
        aria-label="Anrufen unter 0151 56081392"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
        </svg>
        0151 56081392
      </a>
      <p class="mt-4 text-sm text-white/70">
        Erreichbarkeit: Mo–Fr 08:00–17:00 Uhr
      </p>
    </div>
  </section>
</Layout>
