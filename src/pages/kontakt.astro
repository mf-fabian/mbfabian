---
import Layout from '../layouts/Layout.astro';

const web3formsKey = import.meta.env.PUBLIC_WEB3FORMS_KEY;
---

<Layout 
  title="Kontakt"
  description="Kontaktieren Sie Montagebau Fabian. Telefon: 0151 56081392. E-Mail: montagebau-fabian@gmx.de. Wir sind auch im Notfall für Sie da."
>
  <!-- HERO SECTION -->
  <section class="bg-primary py-20 lg:py-28" aria-labelledby="contact-hero-heading">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center">
      <h1 id="contact-hero-heading" class="text-4xl sm:text-5xl font-bold text-white mb-6">
        Kontaktieren Sie uns
      </h1>
      <p class="text-lg text-white/80 max-w-3xl mx-auto leading-relaxed">
        Haben Sie Fragen zu unseren Leistungen oder möchten Sie ein Projekt besprechen? 
        Wir freuen uns auf Ihre Nachricht – oder rufen Sie uns direkt an.
      </p>
    </div>
  </section>

  <!-- CONTACT SECTION -->
  <section class="py-20 lg:py-28 bg-bg" aria-label="Kontaktinformationen und Formular">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20">
        
        <!-- Left Side: Contact Info -->
        <div>
          <h2 class="text-2xl sm:text-3xl font-bold text-primary mb-6">
            Direkter Kontakt
          </h2>
          <p class="text-text-light leading-relaxed mb-10">
            Ob telefonisch, per E-Mail oder über das Kontaktformular – wir sind für Sie erreichbar. 
            Bei Notfällen priorisieren wir Ihre Anfrage und bemühen uns um eine schnellstmögliche Rückmeldung.
          </p>

          <div class="space-y-8">
            <!-- Phone -->
            <div class="flex items-start gap-5">
              <div class="w-14 h-14 bg-accent/10 rounded-xl flex items-center justify-center flex-shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-primary mb-1">Telefon</h3>
                <a href="tel:+4915156081392" class="text-2xl sm:text-3xl font-bold text-accent hover:underline transition-all">
                  0151 56081392
                </a>
                <p class="text-sm text-text-muted mt-1">
                  Mo–Fr 08:00–17:00 Uhr · Notfälle werden priorisiert
                </p>
              </div>
            </div>

            <!-- Email -->
            <div class="flex items-start gap-5">
              <div class="w-14 h-14 bg-accent/10 rounded-xl flex items-center justify-center flex-shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <rect width="20" height="16" x="2" y="4" rx="2"/>
                  <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-primary mb-1">E-Mail</h3>
                <a href="mailto:montagebau-fabian@gmx.de" class="text-lg text-text-light hover:text-accent transition-colors">
                  montagebau-fabian@gmx.de
                </a>
              </div>
            </div>

            <!-- Address -->
            <div class="flex items-start gap-5">
              <div class="w-14 h-14 bg-accent/10 rounded-xl flex items-center justify-center flex-shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/>
                  <circle cx="12" cy="10" r="3"/>
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-primary mb-1">Adresse</h3>
                <address class="not-italic text-text-light">
                  Montagebau Fabian<br/>
                  Manuela Fabian<br/>
                  Am Dohrbaum 5<br/>
                  58239 Schwerte
                </address>
              </div>
            </div>
          </div>

          <!-- Emergency Notice -->
          <div class="mt-12 p-6 bg-accent/10 rounded-xl border border-accent/20">
            <div class="flex items-start gap-4">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-accent flex-shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" x2="12" y1="9" y2="13"/><line x1="12" x2="12.01" y1="17" y2="17"/>
              </svg>
              <div>
                <h3 class="font-semibold text-primary mb-1">Notfall-Service</h3>
                <p class="text-sm text-text-light">
                  Bei dringenden Problemen mit Toren, Türen oder Antrieben rufen Sie uns bitte direkt an. 
                  Wir reagieren schnell und finden eine Lösung.
                </p>
              </div>
            </div>
          </div>
        </div>

        <!-- Right Side: Contact Form -->
        <div>
          <div class="bg-white rounded-xl border border-border p-8 shadow-sm">
            <h2 class="text-2xl font-bold text-primary mb-2">
              Nachricht senden
            </h2>
            <p class="text-text-muted mb-8">
              Füllen Sie das Formular aus und wir melden uns umgehend bei Ihnen.
            </p>

            <!-- Success Message (hidden by default) -->
            <div id="form-success" class="hidden mb-6 p-4 bg-green-50 border border-green-200 rounded-lg" role="status" aria-live="polite">
              <div class="flex items-start gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-green-600 flex-shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                  <polyline points="22 4 12 14.01 9 11.01"/>
                </svg>
                <div>
                  <p class="font-semibold text-green-800">Vielen Dank für Ihre Nachricht!</p>
                  <p class="text-sm text-green-700">Wir haben Ihre Anfrage erhalten und werden uns schnellstmöglich bei Ihnen melden.</p>
                </div>
              </div>
            </div>

            <!-- Error Message (hidden by default) -->
            <div id="form-error" class="hidden mb-6 p-4 bg-red-50 border border-red-200 rounded-lg" role="alert" aria-live="assertive">
              <div class="flex items-start gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-red-600 flex-shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <circle cx="12" cy="12" r="10"/><line x1="15" x2="9" y1="9" y2="15"/><line x1="9" x2="15" y1="9" y2="15"/>
                </svg>
                <div>
                  <p class="font-semibold text-red-800">Ein Fehler ist aufgetreten.</p>
                  <p class="text-sm text-red-700">Bitte versuchen Sie es später erneut oder rufen Sie uns direkt an.</p>
                </div>
              </div>
            </div>

            <form 
              id="contact-form"
              action="https://api.web3forms.com/submit" 
              method="POST"
              class="space-y-6"
              novalidate
            >
              <!-- Web3Forms Access Key -->
              <input type="hidden" name="access_key" value={web3formsKey} />
              
              <!-- Honeypot Field -->
              <input type="checkbox" name="botcheck" class="hidden" style="display: none;" tabindex="-1" autocomplete="off" />
              
              <!-- Redirect after submit -->
              <input type="hidden" name="redirect" value="false" />
              
              <!-- Subject -->
              <input type="hidden" name="subject" value="Neue Kontaktanfrage über montagebau-fabian.de" />
              
              <!-- From Name -->
              <input type="hidden" name="from_name" value="Montagebau Fabian Website" />

              <!-- Name -->
              <div>
                <label for="name" class="block text-sm font-medium text-primary mb-2">
                  Name <span class="text-accent">*</span>
                </label>
                <input 
                  type="text" 
                  id="name" 
                  name="name" 
                  required
                  minlength="2"
                  class="w-full px-4 py-3 rounded-lg border border-border bg-surface text-text placeholder-text-muted focus:outline-none focus:ring-2 focus:ring-accent/50 focus:border-accent transition-all"
                  placeholder="Ihr vollständiger Name"
                  autocomplete="name"
                  aria-required="true"
                  aria-describedby="name-error"
                />
                <p class="hidden text-sm text-red-600 mt-1" id="name-error">Bitte geben Sie Ihren Namen ein.</p>
              </div>

              <!-- Email -->
              <div>
                <label for="email" class="block text-sm font-medium text-primary mb-2">
                  E-Mail <span class="text-accent">*</span>
                </label>
                <input 
                  type="email" 
                  id="email" 
                  name="email" 
                  required
                  class="w-full px-4 py-3 rounded-lg border border-border bg-surface text-text placeholder-text-muted focus:outline-none focus:ring-2 focus:ring-accent/50 focus:border-accent transition-all"
                  placeholder="ihre.email@beispiel.de"
                  autocomplete="email"
                  aria-required="true"
                  aria-describedby="email-error"
                />
                <p class="hidden text-sm text-red-600 mt-1" id="email-error">Bitte geben Sie eine gültige E-Mail-Adresse ein.</p>
              </div>

              <!-- Phone -->
              <div>
                <label for="phone" class="block text-sm font-medium text-primary mb-2">
                  Telefon <span class="text-text-muted font-normal">(optional)</span>
                </label>
                <input 
                  type="tel" 
                  id="phone" 
                  name="phone" 
                  class="w-full px-4 py-3 rounded-lg border border-border bg-surface text-text placeholder-text-muted focus:outline-none focus:ring-2 focus:ring-accent/50 focus:border-accent transition-all"
                  placeholder="0151 12345678"
                  autocomplete="tel"
                />
              </div>

              <!-- Message -->
              <div>
                <label for="message" class="block text-sm font-medium text-primary mb-2">
                  Ihre Nachricht <span class="text-accent">*</span>
                </label>
                <textarea 
                  id="message" 
                  name="message" 
                  required
                  minlength="10"
                  rows="5"
                  class="w-full px-4 py-3 rounded-lg border border-border bg-surface text-text placeholder-text-muted focus:outline-none focus:ring-2 focus:ring-accent/50 focus:border-accent transition-all resize-y"
                  placeholder="Beschreiben Sie Ihr Anliegen oder Projekt..."
                  aria-required="true"
                  aria-describedby="message-error"
                ></textarea>
                <p class="hidden text-sm text-red-600 mt-1" id="message-error">Bitte geben Sie eine Nachricht ein (mindestens 10 Zeichen).</p>
              </div>

              <!-- Privacy Consent -->
              <div class="flex items-start gap-3">
                <input 
                  type="checkbox" 
                  id="privacy" 
                  name="privacy" 
                  required
                  class="mt-1 w-4 h-4 text-accent border-border rounded focus:ring-accent"
                  aria-required="true"
                  aria-describedby="privacy-error"
                />
                <label for="privacy" class="text-sm text-text-light">
                  Ich habe die <a href="/datenschutz" class="text-accent underline hover:no-underline">Datenschutzerklärung</a> gelesen und stimme der Verarbeitung meiner Daten zu. <span class="text-accent">*</span>
                </label>
              </div>
              <p class="hidden text-sm text-red-600 -mt-4" id="privacy-error">Bitte akzeptieren Sie die Datenschutzerklärung.</p>

              <!-- Submit Button -->
              <button 
                type="submit" 
                id="submit-btn"
                class="w-full inline-flex items-center justify-center gap-2 bg-accent text-white px-8 py-4 rounded-lg font-semibold text-base transition-all duration-300 hover:bg-accent/90 hover:scale-[1.02] shadow-lg disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:scale-100"
              >
                <span id="btn-text">Nachricht senden</span>
                <svg id="btn-icon" xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M22 2 11 13"/><path d="m22 2-7 20-4-9-9-4 20-7z"/>
                </svg>
                <svg id="btn-spinner" class="hidden h-5 w-5 animate-spin" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" aria-hidden="true">
                  <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                  <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                </svg>
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  (function() {
    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    const successMsg = document.getElementById('form-success');
    const errorMsg = document.getElementById('form-error');
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement | null;
    const btnText = document.getElementById('btn-text');
    const btnIcon = document.getElementById('btn-icon');
    const btnSpinner = document.getElementById('btn-spinner');

    if (!form) return;

    function showFieldError(fieldId: string, errorId: string, show: boolean) {
      const errorEl = document.getElementById(errorId);
      const field = document.getElementById(fieldId);
      if (errorEl) {
        errorEl.classList.toggle('hidden', !show);
      }
      if (field) {
        field.classList.toggle('border-red-500', show);
        field.classList.toggle('focus:ring-red-200', show);
        field.classList.toggle('focus:border-red-500', show);
        if (show) {
          field.setAttribute('aria-invalid', 'true');
        } else {
          field.removeAttribute('aria-invalid');
        }
      }
    }

    function validateEmail(email: string): boolean {
      const re = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      return re.test(email);
    }

    function setLoading(loading: boolean) {
      if (!submitBtn) return;
      submitBtn.disabled = loading;
      if (btnText) btnText.textContent = loading ? 'Wird gesendet...' : 'Nachricht senden';
      if (btnIcon) btnIcon.classList.toggle('hidden', loading);
      if (btnSpinner) btnSpinner.classList.toggle('hidden', !loading);
    }

    function showSuccess() {
      if (successMsg) successMsg.classList.remove('hidden');
      if (errorMsg) errorMsg.classList.add('hidden');
      form.reset();
    }

    function showError() {
      if (errorMsg) errorMsg.classList.remove('hidden');
      if (successMsg) successMsg.classList.add('hidden');
    }

    form.addEventListener('submit', async function(e) {
      e.preventDefault();
      
      // Hide previous messages
      if (successMsg) successMsg.classList.add('hidden');
      if (errorMsg) errorMsg.classList.add('hidden');

      // Client-side validation
      let isValid = true;

      const name = (document.getElementById('name') as HTMLInputElement)?.value.trim();
      const email = (document.getElementById('email') as HTMLInputElement)?.value.trim();
      const message = (document.getElementById('message') as HTMLTextAreaElement)?.value.trim();
      const privacy = (document.getElementById('privacy') as HTMLInputElement)?.checked;

      if (!name || name.length < 2) {
        showFieldError('name', 'name-error', true);
        isValid = false;
      } else {
        showFieldError('name', 'name-error', false);
      }

      if (!email || !validateEmail(email)) {
        showFieldError('email', 'email-error', true);
        isValid = false;
      } else {
        showFieldError('email', 'email-error', false);
      }

      if (!message || message.length < 10) {
        showFieldError('message', 'message-error', true);
        isValid = false;
      } else {
        showFieldError('message', 'message-error', false);
      }

      if (!privacy) {
        showFieldError('privacy', 'privacy-error', true);
        isValid = false;
      } else {
        showFieldError('privacy', 'privacy-error', false);
      }

      if (!isValid) {
        // Focus first invalid field
        const firstInvalid = form.querySelector('[aria-invalid="true"]') as HTMLElement;
        if (firstInvalid) firstInvalid.focus();
        return;
      }

      // Submit form
      setLoading(true);

      try {
        const formData = new FormData(form);
        const response = await fetch(form.action, {
          method: 'POST',
          body: formData
        });

        const data = await response.json();

        if (response.ok && data.success) {
          showSuccess();
        } else {
          showError();
        }
      } catch (err) {
        showError();
      } finally {
        setLoading(false);
      }
    });

    // Real-time validation on input
    ['name', 'email', 'message'].forEach(function(fieldId) {
      const field = document.getElementById(fieldId);
      if (field) {
        field.addEventListener('input', function() {
          showFieldError(fieldId, fieldId + '-error', false);
        });
      }
    });

    const privacyField = document.getElementById('privacy');
    if (privacyField) {
      privacyField.addEventListener('change', function() {
        showFieldError('privacy', 'privacy-error', false);
      });
    }
  })();
</script>
